{
  "tasks": {
    "dev": "npm run dev",
    "build": "npm run build",
    "watch": "npm run watch",
    "test": "deno test --allow-read --allow-env --allow-sys tests/",
    "test:watch": "deno test --allow-read --allow-env --allow-sys --watch tests/"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "jsdom": "npm:jsdom@^29.0.0",
    "./src/sheet.css": "./tests/dom/css-shim.js"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "esnext"]
  }
}
