# HTTP listen port for uvicorn (Dockerfile / docker compose). Default 8000 if unset.
# PORT=8000

# Partner API base URL (no trailing slash). BFF proxies GET /api/ark/routing/* and POSTs collab payloads to /ark/tunnel.
ARK_BACKEND_URL=

# Comma-separated entries: single segment per spreadsheet root (e.g. clients → /clients) and/or prefix/* (e.g. user_transactions/* → /user_transactions/…). Browser path maps to GET …/routing/{path}.
ARK_UI_ROUTES=clients,records

# Optional. If set, partner backends may POST /api/ark/broadcast with Authorization: Bearer <this> to push sheet.truth to all WebSocket clients.
# ARK_BROADCAST_TOKEN=

# --- Iframe / framing (HTTP headers on every Ark response; edit via .env or container env) ---
# Embed case: parent app at https://example.com loads Ark in <iframe src="https://ark.example.com/clients">.
# ark.example.com and example.com are different origins, so the Ark server must allow the parent origin:
# ARK_IFRAME_FRAME_ANCESTORS=https://example.com
# If you also load the parent from https://www.example.com, list both (each origin string is distinct):
# ARK_IFRAME_FRAME_ANCESTORS=https://example.com https://www.example.com
#
# Value = only what follows “frame-ancestors ” in CSP (space-separated origins). 'self' means the Ark host (e.g. ark.example.com), not the parent frame.
#
# Optional X-Frame-Options (DENY | SAMEORIGIN). Omit for cross-site embeds — SAMEORIGIN only allows framing from ark.example.com itself, not from example.com.
# ARK_IFRAME_X_FRAME_OPTIONS=SAMEORIGIN
