# Node gateway: static UI from `dist/` + HTTP/WebSocket proxy to BACKEND_URL.
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=8080
ENV BACKEND_URL=http://127.0.0.1:3000
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
COPY gateway/server.mjs ./gateway/server.mjs
COPY --from=build /app/dist ./dist
EXPOSE 8080
CMD ["node", "gateway/server.mjs"]
